---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  subtitle?: string;
  crumbs?: Crumb[];
}
const { title, subtitle, crumbs = [] } = Astro.props;
---

<section class="border-b border-navy-100 bg-navy-950">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    {
      crumbs.length > 0 && (
        <nav aria-label="Breadcrumb" class="mb-4">
          <ol class="flex flex-wrap items-center gap-2 text-xs text-navy-100/60">
            {crumbs.map((c, i) => (
              <li class="flex items-center gap-2">
                {c.href ? (
                  <a href={c.href} class="hover:text-gold-400">
                    {c.label}
                  </a>
                ) : (
                  <span class="text-navy-100/80">{c.label}</span>
                )}
                {i < crumbs.length - 1 && <span>/</span>}
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <h1 class="font-serif text-3xl font-semibold text-white sm:text-4xl">
      {title}
    </h1>
    {
      subtitle && (
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-navy-100/80">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
