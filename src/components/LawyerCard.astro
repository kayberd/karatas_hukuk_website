---
import { Image } from "astro:assets";

interface Props {
  name: string;
  title?: string;
  university?: string;
  languages?: string[];
  href: string;
  photo?: ImageMetadata;
}
const { name, title, university, languages = [], href, photo } = Astro.props;
const initials = name
  .replace(/^Av\.?\s*/i, "")
  .split(" ")
  .map((w) => w[0])
  .slice(0, 2)
  .join("");
---

<a
  href={href}
  class="group flex flex-col items-center rounded-md border border-navy-100 bg-white p-6 text-center transition-all hover:border-gold-400 hover:shadow-md"
>
  {
    photo ? (
      <Image
        src={photo}
        alt={`${name} portresi`}
        width={160}
        height={160}
        class="h-28 w-28 rounded-full object-cover"
      />
    ) : (
      <span class="flex h-28 w-28 items-center justify-center rounded-full bg-navy-900 font-serif text-2xl font-semibold text-gold-400">
        {initials}
      </span>
    )
  }
  <h3 class="mt-4 text-lg font-semibold text-navy-900">{name}</h3>
  {title && <p class="text-sm font-medium text-bordo-700">{title}</p>}
  {university && <p class="mt-2 text-xs text-anthracite/70">{university}</p>}
  {
    languages.length > 0 && (
      <p class="mt-1 text-xs text-anthracite/60">{languages.join(" · ")}</p>
    )
  }
</a>
