---
import { site } from "@/config/site";

const waMessage = "Merhaba, bilgi almak istiyorum.";
const waHref = `https://api.whatsapp.com/send?phone=${site.phoneHref.replace("+", "")}&text=${encodeURIComponent(waMessage)}`;
---

<div class="floating-contact" aria-label="Hızlı iletişim">
  <a
    href={waHref}
    class="floating-contact__btn floating-contact__btn--wa"
    target="_blank"
    rel="noopener"
    aria-label="WhatsApp ile mesaj gönder"
  >
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.483-.911zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"></path>
    </svg>
  </a>

  <a
    href={`tel:${site.phoneHref}`}
    class="floating-contact__btn floating-contact__btn--call"
    aria-label="Telefonla ara"
  >
    <svg class="floating-contact__phone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
    </svg>
  </a>
</div>

<style>
  .floating-contact {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 50;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .floating-contact__btn {
    display: flex;
    height: 4.0625rem;
    width: 4.0625rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    color: #fff;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .floating-contact__btn:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  .floating-contact__btn--call svg {
    height: 2.125rem;
    width: 2.125rem;
  }

  .floating-contact__btn--wa svg {
    height: 1.9375rem;
    width: 1.9375rem;
  }

  .floating-contact__btn--wa {
    background: #25d366;
  }

  .floating-contact__btn--call {
    background: #1e3a5f;
  }

  .floating-contact__phone {
    transform-origin: center;
    animation: floating-phone-tilt 3s ease-in-out infinite;
  }

  @keyframes floating-phone-tilt {
    0%, 75%, 100% { transform: rotate(0deg); }
    79% { transform: rotate(-12deg); }
    83% { transform: rotate(12deg); }
    87% { transform: rotate(-12deg); }
    91% { transform: rotate(12deg); }
    95% { transform: rotate(-12deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-contact__phone { animation: none; }
    .floating-contact__btn { transition: none; }
  }
</style>
