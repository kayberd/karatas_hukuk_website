---
import { formatDate } from "@/lib/format";
import { categoryLabels } from "@/config/site";

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category: string;
  href: string;
}
const { title, description, date, author, category, href } = Astro.props;
---

<article
  class="group relative flex flex-col rounded-md border border-navy-100 bg-white p-6 transition-all hover:border-gold-400 hover:shadow-md"
>
  <div class="flex items-center gap-3 text-xs">
    <span
      class="rounded-full bg-bordo-700/10 px-2.5 py-1 font-medium text-bordo-700"
      >{categoryLabels[category] ?? category}</span
    >
    <time datetime={date.toISOString()} class="text-anthracite/60"
      >{formatDate(date)}</time
    >
  </div>
  <h3 class="mt-3 text-lg font-semibold leading-snug text-navy-900">
    <a href={href} class="after:absolute after:inset-0">{title}</a>
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-anthracite/80">
    {description}
  </p>
  <p class="mt-4 text-xs text-anthracite/60">{author}</p>
</article>
