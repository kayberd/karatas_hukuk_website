---
import { nav, site } from "@/config/site";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-navy-100 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-3" aria-label={site.buroName}>
      <span class="flex h-10 w-10 items-center justify-center rounded-sm border border-gold-500 text-gold-600">
        <span class="font-serif text-lg font-semibold">K</span>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-serif text-lg font-semibold text-navy-900"
          >{site.shortName}</span
        >
        <span class="text-[11px] uppercase tracking-widest text-gold-600"
          >Hukuk Bürosu</span
        >
      </span>
    </a>

    <nav class="hidden lg:block" aria-label="Ana menü">
      <ul class="flex items-center gap-6 text-sm font-medium">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "transition-colors hover:text-bordo-700",
                  isActive(item.href)
                    ? "text-bordo-700"
                    : "text-navy-800",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="/iletisim"
      class="hidden rounded-sm bg-navy-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-navy-800 lg:inline-block"
      >İletişime Geçin</a
    >

    <button
      id="menu-toggle"
      class="inline-flex h-10 w-10 items-center justify-center rounded-sm border border-navy-100 text-navy-900 lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menüyü aç/kapat"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-navy-100 bg-white lg:hidden"
    aria-label="Mobil menü"
  >
    <ul class="mx-auto flex max-w-6xl flex-col px-4 py-2 sm:px-6">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "block border-b border-navy-50 py-3 text-sm font-medium",
                isActive(item.href) ? "text-bordo-700" : "text-navy-800",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/iletisim"
          class="mt-3 mb-2 block rounded-sm bg-navy-900 px-4 py-2 text-center text-sm font-medium text-white"
          >İletişime Geçin</a
        >
      </li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(open === false));
  });
</script>
