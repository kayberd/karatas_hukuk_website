---
import { nav, site } from "@/config/site";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-navy-100 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-3" aria-label={site.buroName}>
      <span class="flex h-10 w-10 items-center justify-center rounded-sm border border-gold-500 text-gold-600">
        <span class="font-serif text-lg font-semibold">K</span>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-serif text-lg font-semibold text-navy-900"
          >{site.shortName}</span
        >
        <span class="text-[11px] uppercase tracking-widest text-gold-600"
          >Hukuk Bürosu</span
        >
      </span>
    </a>

    <nav class="hidden lg:block" aria-label="Ana menü">
      <ul class="flex items-center gap-6 text-sm font-medium">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "transition-colors hover:text-bordo-700",
                  isActive(item.href)
                    ? "text-bordo-700"
                    : "text-navy-800",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href={`tel:${site.phoneHref}`}
      class="hidden items-center gap-2 rounded-sm bg-navy-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-navy-800 lg:inline-flex"
    >
      <svg class="phone-tilt h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      Hemen Ara
    </a>

    <div class="flex items-center gap-2 lg:hidden">
      <a
        href={`tel:${site.phoneHref}`}
        class="inline-flex h-10 items-center gap-2 rounded-sm bg-navy-900 px-3 text-sm font-medium text-white transition-colors hover:bg-navy-800"
      >
        <svg class="phone-tilt h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        <span class="hidden sm:inline">Hemen Ara</span>
      </a>

      <button
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-sm border border-navy-100 text-navy-900"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menüyü aç/kapat"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"></path></svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-navy-100 bg-white lg:hidden"
    aria-label="Mobil menü"
  >
    <ul class="mx-auto flex max-w-6xl flex-col px-4 py-2 sm:px-6">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "block border-b border-navy-50 py-3 text-sm font-medium",
                isActive(item.href) ? "text-bordo-700" : "text-navy-800",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={`tel:${site.phoneHref}`}
          class="mt-3 mb-2 flex items-center justify-center gap-2 rounded-sm bg-navy-900 px-4 py-2 text-center text-sm font-medium text-white"
        >
          <svg class="phone-tilt h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Hemen Ara
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .phone-tilt {
    transform-origin: center;
    animation: phone-tilt 3s ease-in-out infinite;
  }

  @keyframes phone-tilt {
    0%, 75%, 100% { transform: rotate(0deg); }
    79% { transform: rotate(-12deg); }
    83% { transform: rotate(12deg); }
    87% { transform: rotate(-12deg); }
    91% { transform: rotate(12deg); }
    95% { transform: rotate(-12deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-tilt { animation: none; }
  }
</style>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(open === false));
  });
</script>
