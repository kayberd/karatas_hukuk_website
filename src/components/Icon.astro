  home: "M3 11l9-7 9 7M5 10v10h14V10",
  family:
    "M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm9 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM3 20v-1a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v1m1-5h2a4 4 0 0 1 4 4v1",
  document:
    "M7 3h7l5 5v13H7zM14 3v5h5M9 13h6M9 17h6",
  scroll:
    "M6 3h10a2 2 0 0 1 2 2v12a2 2 0 0 0 2 2H8a2 2 0 0 1-2-2zM6 3a2 2 0 0 0-2 2v2h4M10 8h5M10 12h5",
  building:
    "M4 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16M8 7h2M8 11h2M8 15h2M14 7h2M14 11h2M2 21h20",
  shield: "M12 3l8 3v5c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z",
  phone:
    "M3 5a2 2 0 0 1 2-2h2l2 5-2 1a12 12 0 0 0 6 6l1-2 5 2v2a2 2 0 0 1-2 2A16 16 0 0 1 3 5z",
  mail: "M3 6h18v12H3zM3 6l9 7 9-7",
  pin: "M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11zM12 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
  "chevron-down": "M6 9l6 6 6-6",
};

const d = paths[name] ?? paths.scale;
---

<svg
