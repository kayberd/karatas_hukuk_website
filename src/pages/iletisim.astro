---
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import Icon from "@/components/Icon.astro";
import { site } from "@/config/site";
---

<Base
  title="İletişim"
  description={`${site.buroName} iletişim bilgileri ve adres.`}
>
  <PageHero
    title="İletişim"
    subtitle="Sorularınız için aşağıdaki kanallardan bize ulaşabilirsiniz."
    crumbs={[{ label: "Anasayfa", href: "/" }, { label: "İletişim" }]}
  />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="max-w-3xl">
    <h2 class="font-serif text-2xl font-semibold text-navy-900">
      {site.buroName}
    </h2>
    <ul class="mt-6 space-y-4 text-sm">
      <li class="flex items-start gap-3">
        <Icon name="pin" class="mt-0.5 h-5 w-5 shrink-0 text-bordo-700" />
        <span>
          {site.address}
        </span>
      </li>
      <li class="flex items-center gap-3">
        <Icon name="phone" class="h-5 w-5 shrink-0 text-bordo-700" />
        <a href={`tel:${site.phoneHref}`} class="hover:text-bordo-700"
          >{site.phone}</a
        >
      </li>
      <li class="flex items-center gap-3">
        <Icon name="mail" class="h-5 w-5 shrink-0 text-bordo-700" />
        <a href={`mailto:${site.email}`} class="hover:text-bordo-700"
          >{site.email}</a
        >
      </li>
    </ul>

    <div class="mt-8 overflow-hidden rounded-md border border-navy-100">
      <iframe
        title="Büro konumu"
        src={site.mapEmbed}
        width="100%"
        height="400"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="block h-[400px] w-full"
        style="border:0;"></iframe>
    </div>
    </div>
  </section>
</Base>
