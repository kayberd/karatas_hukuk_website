---
import { getCollection, render } from "astro:content";
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import InfoBlock from "@/components/InfoBlock.astro";
import { categoryLabels, site } from "@/config/site";
import { formatDate } from "@/lib/format";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const d = article.data;
const { Content } = await render(article);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: d.title,
  description: d.description,
  datePublished: d.date.toISOString(),
  author: { "@type": "Person", name: d.author },
  publisher: { "@type": "Organization", name: site.buroName },
};

const faqSchema =
  d.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: d.faq.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: { "@type": "Answer", text: f.a },
        })),
      }
    : undefined;

const schema = faqSchema ? [articleSchema, faqSchema] : articleSchema;
---

<Base
  title={d.title}
  description={d.description}
  type="article"
  schema={schema}
>
  <PageHero
    title={d.title}
    crumbs={[
      { label: "Anasayfa", href: "/" },
      { label: "Bilgi Bankası", href: "/bilgi-bankasi" },
      {
        label: categoryLabels[d.category] ?? d.category,
        href: `/bilgi-bankasi/kategori/${d.category}`,
      },
    ]}
  />

  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <div class="flex flex-wrap items-center gap-3 text-sm text-anthracite/70">
      <a
        href={`/bilgi-bankasi/kategori/${d.category}`}
        class="rounded-full bg-bordo-700/10 px-3 py-1 font-medium text-bordo-700"
        >{categoryLabels[d.category] ?? d.category}</a
      >
      <time datetime={d.date.toISOString()}>{formatDate(d.date)}</time>
      <span>·</span>
      <span>{d.author}</span>
    </div>

    <div class="prose prose-neutral mt-8 max-w-none">
      <Content />
    </div>

    {
      d.faq.length > 0 && (
        <section class="mt-12">
          <h2 class="font-serif text-2xl font-semibold text-navy-900">
            Sıkça Sorulan Sorular
          </h2>
          <div class="mt-6 divide-y divide-navy-100 rounded-md border border-navy-100">
            {d.faq.map((f) => (
              <details class="group p-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-navy-900">
                  {f.q}
                  <span class="text-gold-600 transition-transform group-open:rotate-45">
                    +
                  </span>
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-anthracite/80">
                  {f.a}
                </p>
              </details>
            ))}
          </div>
        </section>
      )
    }
  </article>

  <InfoBlock />
</Base>
