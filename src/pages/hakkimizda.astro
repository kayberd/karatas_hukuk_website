---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import LawyerCard from "@/components/LawyerCard.astro";
import InfoBlock from "@/components/InfoBlock.astro";
import { site } from "@/config/site";

const lawyers = (await getCollection("lawyers")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Base
  title="Hakkımızda"
  description={`${site.buroName} hakkında bilgi: faaliyet alanları, çalışma ilkeleri ve büro kimliği.`}
>
  <PageHero
    title="Hakkımızda"
    subtitle={`${site.buroName}, ${site.baro}'na kayıtlı bir avukatlık bürosudur.`}
    crumbs={[{ label: "Anasayfa", href: "/" }, { label: "Hakkımızda" }]}
  />

  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <div class="prose prose-neutral max-w-none">
      <h2>Teorik Birikim, Pratik Çözüm: Biz Kimiz?</h2>
      <p>
        Kuruluşumuzdan bu yana temel amacımız; müvekkillerimize sadece avukatlık
        hizmeti sunmak değil, onların hukuki çözüm ortağı olmaktır. {site.buroName}
        olarak güvenilir hukuki danışmanlık sunuyor; netlik, titizlik ve
        dürüstlük ilkelerimizle her aşamada yanınızda yer alıyoruz.
      </p>
      <h2>Vizyonumuz</h2>
      <p>
        Uzmanlık gerektiren hukuki alanlarda, sistematik ve öngörülebilir bir
        çalışma standardı geliştirmek. Hukuki güvenliği esas alan, titiz ve
        sürdürülebilir bir temsil yaklaşımını kurumsal bir yapı içinde devam
        ettirmek.
      </p>
      <h2>Misyonumuz</h2>
      <p>
        Hukuki süreçleri sadeleştiriyor ve müvekkillerimiz için en etkili
        stratejileri hayata geçiriyoruz. Teorik birikimimizi sahadaki pratik
        tecrübemizle birleştirerek, hak kayıplarını önlemek ve kalıcı çözümler
        üretmek için kararlılıkla çalışıyoruz.
      </p>
      <h2>Çalışma ilkelerimiz</h2>
      <ul>
        <li>Dürüstlük ve şeffaflık</li>
        <li>Meslek sırrına ve gizliliğe bağlılık</li>
        <li>Her aşamada bilgilendirme</li>
        <li>Hukuki çerçeveye uygun, ölçülü yaklaşım</li>
      </ul>
      <p>
        Akademik hukuk ve idari yargı başta olmak üzere; ceza hukuku, taşınmaz
        hukuku, yabancılar hukuku, iş hukuku ve aile hukuku alanlarında hizmet
        veriyoruz. Tüm alanları
        <a href="/faaliyet-alanlari">faaliyet alanları</a> sayfamızdan
        inceleyebilirsiniz.
      </p>
    </div>
  </section>

  <section class="bg-navy-50/60">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="font-serif text-2xl font-semibold text-navy-900">
        Avukatlarımız
      </h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          lawyers.map((l) => (
            <LawyerCard
              name={l.data.name}
              title={l.data.title}
              university={l.data.university}
              languages={l.data.languages}
              photo={l.data.photo}
              href={`/avukatlar/${l.data.slug}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <InfoBlock />
</Base>
