---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Sayfa Bulunamadı"
  description="Aradığınız sayfa bulunamadı."
>
  <section
    class="mx-auto flex max-w-3xl flex-col items-center px-4 py-28 text-center sm:px-6"
  >
    <p class="font-serif text-6xl font-semibold text-navy-900">404</p>
    <h1 class="mt-4 font-serif text-2xl font-semibold text-navy-900">
      Sayfa bulunamadı
    </h1>
    <p class="mt-3 text-anthracite/70">
      Aradığınız sayfa taşınmış veya kaldırılmış olabilir.
    </p>
    <a
      href="/"
      class="mt-8 rounded-sm bg-navy-900 px-6 py-3 text-sm font-semibold text-white hover:bg-navy-800"
      >Anasayfaya dön</a
    >
  </section>
</Base>
