---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import PageHero from "@/components/PageHero.astro";
import InfoBlock from "@/components/InfoBlock.astro";
import { site } from "@/config/site";

export async function getStaticPaths() {
  const lawyers = await getCollection("lawyers");
  return lawyers.map((lawyer) => ({
    params: { slug: lawyer.data.slug },
    props: { lawyer },
  }));
}

const { lawyer } = Astro.props;
const d = lawyer.data;
const { Content } = await render(lawyer);

const facts = [
  { label: "Baro", value: d.baro },
  { label: "Baro Sicil No", value: d.baroNo },
  { label: "TBB Sicil No", value: d.sicilNo },
  { label: "Mesleğe Başlama", value: d.startDate },
  { label: "Mezuniyet", value: d.university },
  {
    label: "Yabancı Diller",
    value: d.languages.length ? d.languages.join(", ") : undefined,
  },
].filter((f) => f.value);

const schema = {
  "@context": "https://schema.org",
  "@type": "Attorney",
  name: d.name,
  jobTitle: d.title,
  alumniOf: d.university,
  worksFor: { "@type": "LegalService", name: site.buroName },
};
---

<Base
  title={d.name}
  description={`${d.name} — ${d.baro ?? site.baro}. Mevzuata uygun avukat bilgileri.`}
  schema={schema}
>
  <PageHero
    title={d.name}
    subtitle={d.title}
    crumbs={[
      { label: "Anasayfa", href: "/" },
      { label: "Avukatlar", href: "/avukatlar" },
      { label: d.name },
    ]}
  />

  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[220px_1fr]">
      <div>
        {
          d.photo ? (
            <Image
              src={d.photo}
              alt={`${d.name} portresi`}
              width={220}
              height={260}
              class="w-full rounded-md object-cover"
            />
          ) : (
            <div class="flex aspect-[4/5] items-center justify-center rounded-md bg-navy-900 font-serif text-4xl text-gold-400">
              {d.name.replace(/^Av\.?\s*/i, "").charAt(0)}
            </div>
          )
        }
        <dl class="mt-6 space-y-3 text-sm">
          {
            facts.map((f) => (
              <div>
                <dt class="text-xs uppercase tracking-wide text-anthracite/60">
                  {f.label}
                </dt>
                <dd class="font-medium text-navy-900">{f.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <div class="prose prose-neutral max-w-none">
        <Content />
      </div>
    </div>
  </section>

  <InfoBlock />
</Base>
