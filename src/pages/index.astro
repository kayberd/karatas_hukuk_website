---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import AreaCard from "@/components/AreaCard.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import InfoBlock from "@/components/InfoBlock.astro";
import Icon from "@/components/Icon.astro";
import { site } from "@/config/site";

const areas = (await getCollection("areas")).sort(
  (a, b) => a.data.order - b.data.order,
);
const topAreas = areas.slice(0, 6);

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const latest = articles.slice(0, 3);
---

<Base
  title={site.shortName}
  description="Karataş Hukuk Bürosu — Ankara Barosu'na kayıtlı avukatlık bürosu. Faaliyet alanları ve hukuki bilgilendirme."
>
  <section class="relative overflow-hidden bg-navy-950">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 80% 20%, #c9a85c 0, transparent 45%);"
    >
    </div>
    <div
      class="relative mx-auto flex max-w-6xl flex-col gap-6 px-4 py-20 sm:px-6 sm:py-28"
    >
      <span
        class="inline-flex w-fit items-center gap-2 rounded-full border border-gold-500/40 px-3 py-1 text-xs uppercase tracking-widest text-gold-400"
      >
        <Icon name="scale" class="h-4 w-4" />
        {site.baro}
      </span>
      <h1
        class="max-w-3xl font-serif text-4xl font-semibold leading-tight text-white sm:text-5xl"
      >
        Güven ve dürüstlükle yanınızdayız
      </h1>
      <p class="max-w-2xl text-lg leading-relaxed text-navy-100/80">
        {site.buroName} olarak güvenilir hukuki danışmanlık sunuyoruz. Netlik,
        titizlik ve dürüstlük ilkelerimizle; süreci anlaşılır kılmak ve
        haklarınızı hukuki çerçevede korumak için her aşamada yanınızdayız.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href="/faaliyet-alanlari"
          class="rounded-sm bg-gold-500 px-6 py-3 text-sm font-semibold text-navy-950 transition-colors hover:bg-gold-400"
          >Faaliyet Alanları</a
        >
        <a
          href="/iletisim"
          class="rounded-sm border border-white/30 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
          >İletişim</a
        >
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-bordo-700">
          Çalışma Alanları
        </p>
        <h2 class="mt-2 font-serif text-3xl font-semibold text-navy-900">
          Faaliyet Alanlarımız
        </h2>
      </div>
      <a
        href="/faaliyet-alanlari"
        class="hidden shrink-0 text-sm font-medium text-bordo-700 hover:underline sm:block"
        >Tümünü gör</a
      >
    </div>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        topAreas.map((area) => (
          <AreaCard
            title={area.data.title}
            summary={area.data.summary}
            icon={area.data.icon}
            href={`/faaliyet-alanlari/${area.data.slug}`}
          />
        ))
      }
    </div>
  </section>

  <section class="bg-navy-50/60">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 sm:px-6 md:grid-cols-3">
      {
        [
          {
            icon: "scale",
            t: "Sizi Anlıyoruz",
            d: "Hukuki sürecin stresini ve belirsizliğini azaltmak için ilk adımımız, size zaman ayırmak.",
          },
          {
            icon: "document",
            t: "Stratejik Planlama",
            d: "Stratejimizi sizin hedefleriniz belirler. Tüm süreç boyunca açık iletişimi ve kişiselleştirilmiş desteği esas alıyoruz.",
          },
          {
            icon: "shield",
            t: "Kararlı Takip ve Sonuç",
            d: "Hukuki süreç titizlikle yürütülür ve sonuna kadar takip edilir; her aşamada istikrar ve kararlılık sağlanır.",
          },
        ].map((item) => (
          <div>
            <span class="flex h-11 w-11 items-center justify-center rounded-md bg-navy-900 text-gold-400">
              <Icon name={item.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-lg font-semibold text-navy-900">{item.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-anthracite/80">
              {item.d}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-bordo-700">
          Blog
        </p>
        <h2 class="mt-2 font-serif text-3xl font-semibold text-navy-900">
          Güncel Yazılar
        </h2>
      </div>
      <a
        href="/blog"
        class="hidden shrink-0 text-sm font-medium text-bordo-700 hover:underline sm:block"
        >Tümünü gör</a
      >
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {
        latest.map((a) => (
          <ArticleCard
            title={a.data.title}
            description={a.data.description}
            date={a.data.date}
            author={a.data.author}
            category={a.data.category}
            href={`/blog/${a.data.slug}`}
          />
        ))
      }
    </div>
  </section>

  <section class="bg-navy-50/60">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <p class="text-sm font-medium uppercase tracking-widest text-bordo-700">
        Sıkça Sorulan Sorular
      </p>
      <h2 class="mt-2 font-serif text-3xl font-semibold text-navy-900">
        Merak Edilenler
      </h2>
      <p class="mt-3 text-anthracite/80">
        Müvekkillerimizin sıkça sorduğu sorular ve yanıtları
      </p>
      <div class="mt-8 space-y-3">
        {
          [
            {
              q: "Çankaya'da avukata nasıl başvurabilirim?",
              a: "Çankaya bölgesinde avukata başvurmak için büromuzla telefon veya e-posta aracılığıyla iletişime geçerek randevu alabilirsiniz. İlk görüşmede hukuki sorununuz değerlendirilir ve süreç hakkında bilgilendirme yapılır. Büromuz Kocatepe Mahallesi, Mithatpaşa Caddesi Ahenk Apartmanı'nda yer almaktadır.",
            },
            {
              q: "Kızılay ve çevresinde avukatlık hizmeti veriyor musunuz?",
              a: "Evet, büromuz Kızılay, Çankaya ve çevre bölgelerde ikamet eden veya bu bölgede hukuki sorun yaşayan müvekkillerine avukatlık ve hukuki danışmanlık hizmeti sunmaktadır. Büromuz Çankaya/Ankara'nın merkezi konumunda, Kocatepe Mahallesi'nde bulunmaktadır.",
            },
            {
              q: "Hangi hukuk alanlarında hizmet veriyorsunuz?",
              a: "Ceza hukuku, aile hukuku (boşanma, velayet, nafaka), tazminat hukuku, idari yargı, taşınmaz hukuku, iş hukuku, yabancılar hukuku ve akademik danışmanlık alanlarında avukatlık ve danışmanlık hizmeti sunmaktayız.",
            },
            {
              q: "Ankara Adliyesi'nde dava takibi yapıyor musunuz?",
              a: "Evet, büromuz Ankara Adliyesi başta olmak üzere Ankara genelindeki adliyelerde dava takibi yapmaktadır. Ceza mahkemeleri, aile mahkemeleri, asliye hukuk, iş mahkemeleri ve icra dairelerinde müvekkillerimizi temsil etmekteyiz.",
            },
            {
              q: "İlk görüşmede ne yapılır?",
              a: "İlk görüşmede hukuki sorununuz dinlenir, mevcut bilgi ve belgeler incelenir. Ardından ilgili mevzuat çerçevesinde hukuki değerlendirme yapılarak sürecin nasıl ilerleyeceği hakkında bilgilendirme yapılır. Bu görüşme, avukat-müvekkil ilişkisinin kurulup kurulmayacağına karar verilen aşamadır.",
            },
            {
              q: "Arabuluculuk hizmeti veriyor musunuz?",
              a: "İş hukuku ve ticaret hukuku gibi zorunlu arabuluculuk kapsamındaki uyuşmazlıklarda müvekkillerimize arabuluculuk süreçlerinde avukat olarak destek sağlamaktayız. Arabuluculuk, mahkeme dışında tarafların uzlaşmasını hedefleyen alternatif bir uyuşmazlık çözüm yöntemidir.",
            },
            {
              q: "Randevu almadan gelebilir miyim?",
              a: "Randevu alınması tavsiye edilmektedir. Bu sayede size yeterli zaman ayrılabilir ve hukuki sorununuz detaylıca değerlendirilebilir. Randevu için " + site.phone + " numaralı telefonu arayabilir veya web sitemizdeki iletişim formunu doldurabilirsiniz.",
            },
            {
              q: "Online hukuki danışmanlık alabilir miyim?",
              a: "Evet, Ankara dışında ikamet eden veya büroya gelme imkanı olmayan müvekkillerimize telefon veya görüntülü görüşme aracılığıyla hukuki danışmanlık hizmeti sunulmaktadır. Detaylı bilgi için iletişim kanallarımızdan bize ulaşabilirsiniz.",
            },
          ].map((item) => (
            <details class="group rounded-sm border border-navy-900/10 bg-white">
              <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-medium text-navy-900 [&::-webkit-details-marker]:hidden">
                {item.q}
                <Icon
                  name="chevron-down"
                  class="h-5 w-5 shrink-0 text-bordo-700 transition-transform group-open:rotate-180"
                />
              </summary>
              <p class="border-t border-navy-900/10 px-5 py-4 text-sm leading-relaxed text-anthracite/80">
                {item.a}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <InfoBlock />
</Base>
